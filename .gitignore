# ════════════════════════════════════════════════════════════
#  보안: 민감 데이터 파일 — 절대 커밋 금지
#  (구독 원천 데이터: 엑셀 / 파켓)
# ════════════════════════════════════════════════════════════
# Excel
*.xlsx
*.xls
*.xlsm
*.xlsb
*.xlt
*.xltx
*.xltm

# Parquet
*.parquet
*.pq

# 카테고리 매핑 데이터 (모델 / 판매처 실데이터)
0.Category/*.csv

# ════════════════════════════════════════════════════════════
#  시크릿 / 환경변수
# ════════════════════════════════════════════════════════════
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
secrets.*
credentials.*

# ════════════════════════════════════════════════════════════
#  Python 캐시 / 빌드
# ════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so

# 가상환경
.venv/
venv/
env/
ENV/

# 패키징 / 빌드 산출물
build/
dist/
*.egg
*.egg-info/
.eggs/
wheels/

# 테스트 / 타입 / 린트 캐시
.pytest_cache/
.mypy_cache/
.ruff_cache/
.dmypy.json
.cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Jupyter
.ipynb_checkpoints/

# ════════════════════════════════════════════════════════════
#  웹 크롤러 런타임 데이터
# ════════════════════════════════════════════════════════════
*.duckdb
*.duckdb.wal

WebCrawlDB/raw/**
WebCrawlDB/logs/**
WebCrawlDB/warehouse/**
WebCrawlDB/exports/**
!WebCrawlDB/raw/.gitkeep
!WebCrawlDB/logs/.gitkeep
!WebCrawlDB/warehouse/.gitkeep
!WebCrawlDB/exports/.gitkeep
!WebCrawlDB/schema.sql

# ════════════════════════════════════════════════════════════
#  로그 / 임시 파일
# ════════════════════════════════════════════════════════════
*.log
logs/
tmp/
temp/
*.tmp
*.bak

# ════════════════════════════════════════════════════════════
#  IDE / 에디터
# ════════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~

# ════════════════════════════════════════════════════════════
#  OS 생성 파일
# ════════════════════════════════════════════════════════════
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# 분석 결과 차트 (생성 파일 — 커밋 불필요)
