# 이 파일을 .env 로 복사한 뒤 값을 채우세요. (.env 는 커밋되지 않습니다)

# 데이터 루트 경로
# - 비워두면 운영 기본값(V:\한국 정수기 계정) 사용
# - 개발 환경에서는 로컬 데이터 폴더 경로를 지정
WATER_BASE_DIR=C:\dev\water_data

# ── 챗봇 LLM (우선순위: OpenAI > Azure, 둘 다 없으면 키워드 fallback) ──

# (A) 개인 OpenAI 키 — 이것만 넣으면 바로 동작 (개발 환경 권장)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# (B) Azure OpenAI — 운영(사내망)용. OPENAI_API_KEY 가 비어 있을 때만 사용
AZURE_OAI_ENDPOINT=
AZURE_OAI_KEY=
AZURE_OAI_DEPLOYMENT=
